rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user has a specific role
    function hasRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Users can read their own user document
    // Users cannot change their own role
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
      allow delete: if hasRole('ADMIN');
    }

    // Bookings can be read by the user who created them or by a pandit or admin
    // Bookings can only be created by authenticated users
    // Bookings can only be updated by the user who created them (for cancellation), or by a pandit or admin
    match /bookings/{bookingId} {
      allow read: if resource.data.userId == request.auth.uid || hasRole('PANDIT') || hasRole('ADMIN');
      allow create: if request.auth.uid != null;
      allow update: if (resource.data.userId == request.auth.uid && request.resource.data.status == 'Cancelled') || hasRole('PANDIT') || hasRole('ADMIN');
      allow delete: if hasRole('ADMIN');
    }

    // Pandits can be read by any authenticated user
    // Pandits can only be created, updated, or deleted by an admin
    match /pandits/{panditId} {
      allow read: if request.auth.uid != null;
      allow create, update, delete: if hasRole('ADMIN');
    }

    // Consultations can be read by the user or the pandit involved, or by an admin
    // Consultations can be created by any authenticated user
    // Consultations can be updated by the user or the pandit involved, or by an admin
    match /consultations/{consultationId} {
      allow read, update: if resource.data.userId == request.auth.uid || resource.data.panditId == request.auth.uid || hasRole('ADMIN');
      allow create: if request.auth.uid != null;
      allow delete: if hasRole('ADMIN');
    }

    // Reviews can be read by anyone
    // Reviews can be created by any authenticated user
    // Reviews can only be updated or deleted by an admin
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth.uid != null;
      allow update, delete: if hasRole('ADMIN');
    }

    // Products can be read by anyone
    // Products can only be created, updated, or deleted by an admin
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if hasRole('ADMIN');
    }
  }
}