rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Roles stored as lowercase: 'user', 'pandit', 'admin'
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && callerRole() == 'admin';
    }

    function isPandit() {
      return isAuthenticated() && callerRole() == 'pandit';
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      // Prevent self-escalation: role field must not change
      allow update: if isAuthenticated() && isOwner(userId)
                    && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    // ── bookings ───────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.panditId == request.auth.uid
                      || isAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (
                        (resource.data.userId == request.auth.uid
                          && request.resource.data.status == 'cancelled')
                        || (resource.data.panditId == request.auth.uid && isPandit())
                        || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ── consultation_sessions ──────────────────────────────────────────────
    match /consultation_sessions/{sessionId} {
      allow read, update: if isAuthenticated()
                          && (resource.data.userId == request.auth.uid
                              || resource.data.panditId == request.auth.uid
                              || isAdmin());
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── consultation_slots ─────────────────────────────────────────────────
    // Admin-managed time windows that users can browse and book
    match /consultation_slots/{slotId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── chat_messages ──────────────────────────────────────────────────────
    match /chat_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── pandit_profiles ────────────────────────────────────────────────────
    match /pandit_profiles/{panditId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(panditId);
      allow update: if isAuthenticated()
                    && (
                        (isOwner(panditId) && isPandit()
                          && request.resource.data.isVerified == resource.data.isVerified)
                        || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ── pandits (legacy) ───────────────────────────────────────────────────
    match /pandits/{panditId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── pooja_packages ─────────────────────────────────────────────────────
    match /pooja_packages/{packageId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── poojas (legacy) ────────────────────────────────────────────────────
    match /poojas/{poojaId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── orders ─────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── shop products ──────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /shop_products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── special_poojas ─────────────────────────────────────────────────────
    match /special_poojas/{poojaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── notifications ──────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['isRead', 'updatedAt']);
      allow delete: if isAdmin();
    }

  }
}
